[flake8]
max-line-length = 127
exclude = 
    .git,
    __pycache__,
    .pytest_cache,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .cache,
    htmlcov,
    .coverage
ignore = 
    E203,  # whitespace before ':'
    E266,  # too many '#' for block comment
    W503,  # line break before binary operator
    E402,  # module level import not at top of file
per-file-ignores =
    __init__.py:F401
    tests/*:S101